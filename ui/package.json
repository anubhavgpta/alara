{
  "name": "alara-ui",
  "version": "1.0.0",
  "private": true,
  "description": "ALARA Electron overlay UI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "dependencies": {
    "electron": "^35.0.0"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.alara.ui",
    "productName": "ALARA",
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "../",
        "to": "python-project",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  }
}
