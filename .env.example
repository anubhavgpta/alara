# Copy this to .env and fill in values

# Wake word sensitivity (0.0 - 1.0, higher = more sensitive)
WAKE_WORD_THRESHOLD=0.5
WAKE_WORD=hey_jarvis

# Transcriber backend: whisper or deepgram
TRANSCRIBER_BACKEND=deepgram

# Deepgram STT
DEEPGRAM_API_KEY=

# Whisper (used when TRANSCRIBER_BACKEND=whisper)
WHISPER_MODEL=base.en
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# Gemini intent engine
GEMINI_API_KEY = AIzaSyAoNl3hCRgCH93JZU7nMaAna7KVkjcogCY
GEMINI_MODEL = gemini-2.5-flash

# Alara behavior
SILENCE_TIMEOUT_MS=1500
DEBUG=false
